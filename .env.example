# 数据模式: akshare(免token现拉,推荐) / qcore(本机数据湖,最快) / jnb(Tushare,休眠) / websearch(纯对话)
DATA_MODE=akshare

# qcore 数据湖目录（仅 DATA_MODE=qcore 时必填，指向 量化交易 项目的 data/ 目录）
# QCORE_DATA_DIR=/path/to/量化交易/data

# Tushare 配置（仅 DATA_MODE=jnb 时需要；jnb 已休眠保留，详见 docs/adr/0001-retire-tushare-backend.md）
# 需先安装后端：pip install "tushare>=1.4.0"
# TUSHARE_TOKEN=
# TUSHARE_API_URL=
# TUSHARE_VERIFY_TOKEN_URL=

# 数据库
DATA_DIR=data
DB_PATH=data/stock_data.db

# LLM 配置（可选；意图识别后的回答生成，未配置则仅显示识别结果）
# LLM_API_KEY=

# 向量知识库（可选，默认关闭）
# KB_ENABLED=true
# KB_API_URL=http://localhost:8000
